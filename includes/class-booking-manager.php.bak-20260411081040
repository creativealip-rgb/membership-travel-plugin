    public function render_admin_booking_column($column, $post_id) {
        switch ($column) {
            case 'booking_code':
                echo esc_html(get_post_meta($post_id, '_booking_code', true) ?: '—');
                break;

            case 'traveler':
                $name = get_post_meta($post_id, '_customer_name', true);
                $email = get_post_meta($post_id, '_customer_email', true);
                echo '<strong>' . esc_html($name ?: 'Traveler') . '</strong>';
                if ($email) {
                    echo '<br><a href="mailto:' . esc_attr($email) . '">' . esc_html($email) . '</a>';
                }
                break;

            case 'tour':
                $tour_id = absint(get_post_meta($post_id, '_tour_id', true));
                if ($tour_id) {
                    echo '<a href="' . esc_url(get_edit_post_link($tour_id)) . '">' . esc_html(get_the_title($tour_id)) . '</a>';
                } else {
                    echo '—';
                }
                break;

            case 'travel_date':
                $travel_date = get_post_meta($post_id, '_travel_date', true);
                echo $travel_date ? esc_html(wp_date(get_option('date_format'), strtotime($travel_date))) : '—';
                break;

            case 'booking_state':
                $this->render_status_badge(get_post_meta($post_id, '_booking_status', true));
                break;

            case 'payment_proof':
                $proof_id = absint(get_post_meta($post_id, '_payment_proof', true));
                if ($proof_id) {
                    echo '<a href="' . esc_url(wp_get_attachment_url($proof_id)) . '" target="_blank" rel="noopener">Bukti terupload</a>';
                } else {
                    echo '<span style="color:#94a3b8;">Belum ada bukti</span>';
                }
                break;

            case 'total':
                $total = absint(get_post_meta($post_id, '_total_amount', true));
                echo 'Rp ' . esc_html(number_format($total, 0, ',', '.'));
                break;
        }
    }

    private function render_status_badge($status) {
        $map = [
            'pending_payment' => ['Menunggu pembayaran', '#92400e', '#fef3c7'],
            'payment_uploaded' => ['Bukti masuk', '#1d4ed8', '#dbeafe'],
            'paid' => ['Lunas', '#065f46', '#d1fae5'],
            'confirmed' => ['Dikonfirmasi', '#166534', '#dcfce7'],
            'completed' => ['Selesai', '#166534', '#dcfce7'],
            'cancelled' => ['Dibatalkan', '#b91c1c', '#fee2e2'],
            'refunded' => ['Refund', '#6b21a8', '#f3e8ff'],
        ];

        [$label, $color, $bg] = $map[$status] ?? [ucwords(str_replace('_', ' ', (string) $status)), '#334155', '#e2e8f0'];

        echo '<span style="display:inline-flex;align-items:center;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:700;color:' . esc_attr($color) . ';background:' . esc_attr($bg) . ';">' . esc_html($label) . '</span>';
    }

    public function render_admin_meta_box($post) {
        $booking_id = $post->ID;
        $status = get_post_meta($booking_id, '_booking_status', true);
        $booking_code = get_post_meta($booking_id, '_booking_code', true);
        $tour_id = absint(get_post_meta($booking_id, '_tour_id', true));
        $proof_id = absint(get_post_meta($booking_id, '_payment_proof', true));
        $proof_url = $proof_id ? wp_get_attachment_url($proof_id) : '';
