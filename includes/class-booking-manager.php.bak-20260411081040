        echo '</div>';
    }

    public function handle_admin_status_update() {
        if (!current_user_can('edit_posts')) {
            wp_die(__('Unauthorized', 'travel-membership-pro'));
        }

        $booking_id = absint($_POST['booking_id'] ?? 0);
        $new_status = sanitize_text_field($_POST['new_status'] ?? '');
        $admin_note = sanitize_textarea_field($_POST['admin_note'] ?? '');

        if (!$booking_id || !wp_verify_nonce($_POST['tmpb_admin_status_nonce'] ?? '', 'tmpb_admin_update_status_' . $booking_id)) {
            wp_die(__('Invalid request', 'travel-membership-pro'));
        }

        $valid_statuses = ['pending_payment', 'payment_uploaded', 'paid', 'confirmed', 'cancelled', 'completed', 'refunded'];
        $redirect_to = esc_url_raw($_POST['redirect_to'] ?? '');
        if (!$redirect_to) {
            $redirect_to = add_query_arg(['post' => $booking_id, 'action' => 'edit'], admin_url('post.php'));
        }

        if (!in_array($new_status, $valid_statuses, true)) {
            wp_safe_redirect(add_query_arg(['tmpb_notice' => 'invalid_status'], $redirect_to));
            exit;
        }

        $history = get_post_meta($booking_id, '_admin_status_history', true);
        if (!is_array($history)) {
            $history = [];
        }

        $history[] = [
            'status' => $new_status,
            'note' => $admin_note,
            'user_id' => get_current_user_id(),
            'at' => current_time('mysql'),
        ];
        update_post_meta($booking_id, '_admin_status_history', $history);

        $this->update_status($booking_id, $new_status);

        if ($admin_note !== '') {
            update_post_meta($booking_id, '_latest_admin_note', $admin_note);
        }

        wp_safe_redirect(add_query_arg(['tmpb_notice' => 'status_updated'], $redirect_to));
        exit;
    }
